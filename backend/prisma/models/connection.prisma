model Connection {
  id               String             @id @default(cuid())
  name             String
  dialect          Dialect
  // AES-256-GCM ciphertext blob. Contains {host,port,user,password,database,sslMode,extra}
  credentialsCt    String
  readOnly         Boolean            @default(false)
  statementTimeoutMs Int              @default(30000)
  /// When true, `credentialsCt` was encrypted client-side with a key derived
  /// from a user passphrase. The server cannot decrypt these credentials on
  /// its own — the user must supply the derived key with each request. This
  /// disables scheduled queries and webhooks for the connection.
  clientHeldKey    Boolean            @default(false)
  /// Argon2id salt used for the client-side key derivation. Null unless
  /// `clientHeldKey=true`. Safe to expose over the API — a salt without the
  /// passphrase gives an attacker nothing.
  clientKeyKdfSalt String?
  ownerId          String
  owner            User               @relation("OwnedConnections", fields: [ownerId], references: [id], onDelete: Cascade)
  workspaceId      String?
  workspace        Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  members          ConnectionMember[]
  tableGrants      TableGrant[]
  scheduledQueries ScheduledQuery[]
  slowQueryLogs    SlowQueryLog[]
  webhooks         Webhook[]
  columnMasks     ColumnMask[]
  auditLogs        AuditLog[]
  savedQueries     SavedQuery[]
  comments         Comment[]
  schemaSnapshots  SchemaSnapshot[]
  dashboards       Dashboard[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([ownerId])
  @@index([workspaceId])
}
