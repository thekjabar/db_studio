# Shared Postgres — the SAME database v1 uses (copy DATABASE_URL from backend/.env).
DATABASE_URL=postgres://user:pass@dbdash-db:5432/dbdash
# v2 issues its own access JWT; independent of v1 refresh rotation.
V2_JWT_SECRET=change-me-to-a-long-random-string
V2_JWT_TTL_SECS=3600
V2_MAX_ROWS=1000
V2_DB_POOL=10
PORT=3010
RUST_LOG=queryschema_v2=info
