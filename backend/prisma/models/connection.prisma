model Connection {
  id               String             @id @default(cuid())
  name             String
  dialect          Dialect
  // AES-256-GCM ciphertext blob. Contains {host,port,user,password,database,sslMode,extra}
  credentialsCt    String
  readOnly         Boolean            @default(false)
  statementTimeoutMs Int              @default(30000)
  /// Optional slow-query alerting: queries exceeding this threshold email
  /// the alert address (rate-limited to avoid storms).
  slowQueryAlertMs    Int?
  slowQueryAlertEmail String?
  /// When true, `credentialsCt` was encrypted client-side with a key derived
  /// from a user passphrase. The server cannot decrypt these credentials on
  /// its own — the user must supply the derived key with each request. This
  /// disables scheduled queries and webhooks for the connection.
  clientHeldKey    Boolean            @default(false)
  /// Argon2id salt used for the client-side key derivation. Null unless
  /// `clientHeldKey=true`. Safe to expose over the API — a salt without the
  /// passphrase gives an attacker nothing.
  clientKeyKdfSalt String?
  /// How the cloud reaches this database:
  ///   "direct" — cloud connects straight to host:port (or via SSH tunnel).
  ///   "agent"  — cloud relays queries to a WorkspaceAgent running inside the
  ///              customer's network, which originates the DB connection
  ///              locally. For IP-allowlisted DBs the cloud can never reach.
  connectVia       String             @default("direct")
  /// Which agent serves this connection when connectVia = "agent".
  agentId          String?
  agent            WorkspaceAgent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  ownerId          String
  owner            User               @relation("OwnedConnections", fields: [ownerId], references: [id], onDelete: Cascade)
  workspaceId      String?
  workspace        Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  members          ConnectionMember[]
  tableGrants      TableGrant[]
  scheduledQueries ScheduledQuery[]
  slowQueryLogs    SlowQueryLog[]
  planSnapshots    PlanSnapshot[]
  webhooks         Webhook[]
  columnMasks     ColumnMask[]
  auditLogs        AuditLog[]
  savedQueries     SavedQuery[]
  comments         Comment[]
  schemaSnapshots  SchemaSnapshot[]
  dashboards       Dashboard[]
  sharedQueries    SharedQuery[]
  snippets         Snippet[]
  reviewRequests   QueryReviewRequest[]
  notebooks        Notebook[]
  rowFilters       RowFilter[]
  schemaDocs       SchemaDoc[]
  aiChats          AiChat[]
  /// Optional list of read-replica credentials. Shape:
  ///   [{ label, host, port, user, password, database, sslMode? }]
  /// When set, SELECT statements are routed to a random replica with
  /// health-check fallback to the primary. Stored as encrypted JSON under
  /// the same envelope as `credentialsCt` (purpose "conn:<id>:replicas").
  replicasCt       String?
  /// When true, EDITOR users cannot run DESTRUCTIVE statements directly —
  /// they must submit a review request for an OWNER to approve.
  requireReview    Boolean             @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([ownerId])
  @@index([workspaceId])
}
