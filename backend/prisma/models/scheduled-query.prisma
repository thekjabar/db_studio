/// A SQL query that runs on a cron schedule against a specific connection.
/// Execution lifecycle lives in the bullmq `schedules:exec` queue; the DB row
/// is the source of truth for the schedule definition and a summary of the
/// last run.
model ScheduledQuery {
  id             String   @id @default(cuid())
  connectionId   String
  connection     Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name           String
  cron           String
  timezone       String?
  sqlText        String
  /// Comma-separated list of recipient email addresses.
  emailTo        String
  /// Optional Slack incoming-webhook URL. When set, a Slack message is
  /// posted in addition to (or instead of) email.
  slackWebhook   String?
  /// When set, this schedule behaves as an alert: the SQL's result is
  /// evaluated against the condition and notifications only fire when
  /// the condition matches. Null means "always notify" (plain schedule).
  /// Shape: { column: string, op: 'gt'|'gte'|'lt'|'lte'|'eq'|'neq'|'rows_gt'|'rows_eq', value: number }
  alertCondition Json?
  /// Suppress duplicate alerts: once fired, wait at least this many minutes
  /// before re-evaluating. Avoids paging on every cron tick while a metric
  /// stays above threshold.
  alertCooldownMin Int?
  /// Last time an alert fired (evaluated to true + notified). Used with
  /// `alertCooldownMin` to decide whether to fire again.
  lastAlertedAt  DateTime?
  enabled        Boolean  @default(true)
  lastRunAt      DateTime?
  lastStatus     ScheduledRunStatus?
  nextRunAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  runs           ScheduledQueryRun[]

  @@index([ownerId])
  @@index([connectionId])
}

model ScheduledQueryRun {
  id               String   @id @default(cuid())
  scheduleId       String
  schedule         ScheduledQuery @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  startedAt        DateTime @default(now())
  finishedAt       DateTime?
  status           ScheduledRunStatus
  rowCount         Int?
  durationMs       Int?
  errorMessage     String?
  /// First N rows of output as JSON for inline preview in the UI.
  resultPreview    Json?
  emailDelivered   Boolean  @default(false)
  emailError       String?
  /// For alert-type schedules: did the condition match on this run?
  alertTriggered   Boolean  @default(false)
  /// Free-form summary of the condition evaluation (e.g. "count=123 > 100").
  alertSummary     String?

  @@index([scheduleId, startedAt(sort: Desc)])
}
