model User {
  id              String            @id @default(cuid())
  email           String            @unique
  passwordHash    String
  displayName     String?
  density         Density           @default(MEDIUM)
  totpSecret      TotpSecret?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  refreshTokens   RefreshToken[]
  connections     Connection[]      @relation("OwnedConnections")
  memberships     ConnectionMember[]
  auditLogs       AuditLog[]
  savedQueries    SavedQuery[]

  @@index([email])
}
