# Example Caddyfile for putting HTTPS in front of the DB Studio frontend.
# Copy this to `Caddyfile`, replace DB_STUDIO_DOMAIN with your domain, and
# uncomment the `caddy:` service in docker-compose.yml.
#
# Caddy handles certificate issuance + renewal via Let's Encrypt automatically.
# Requires:
#   - A public DNS A/AAAA record pointing DB_STUDIO_DOMAIN -> this host's IP
#   - Ports 80 and 443 reachable from the public internet (for the ACME challenge)
#
# For staging / non-public environments, replace the domain line with `:443`
# and Caddy will use a self-signed cert — browsers warn, but it works.

DB_STUDIO_DOMAIN {
    encode zstd gzip

    # The frontend container (nginx) already serves the SPA and reverse-
    # proxies /api + /socket.io to the api container. Caddy just terminates
    # TLS in front of that.
    reverse_proxy frontend:80 {
        # Preserve the original Host so the API sees the real domain in
        # cookies and redirects.
        header_up Host {host}
        header_up X-Forwarded-Proto https
        header_up X-Real-IP {remote_host}
    }

    # Security headers — backstop in case upstream forgets.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }
}
