{
  "$schema": "https://swc.rs/schema.json",
  "sourceMaps": true,
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true
    },
    "keepClassNames": true,
    "baseUrl": "./",
    "target": "es2022"
  },
  "module": {
    "type": "commonjs",
    "strictMode": true,
    "noInterop": false
  },
  "exclude": [
    ".*\\.spec\\.ts$"
  ]
}
