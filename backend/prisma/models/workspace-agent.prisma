/// A network agent runs INSIDE a customer's network and proxies DB access so
/// the cloud never connects to the database directly. Used for databases whose
/// IP allowlist will never include the cloud server (or an SSH bastion). One
/// agent is shared per workspace and can serve multiple connections.
///
/// The agent authenticates to the cloud relay with a pairing token (same scheme
/// as ApiKey: sha256 for O(1) lookup + argon2id verify). It opens an OUTBOUND
/// WebSocket to the cloud, so no inbound ports are exposed on the customer side.
model WorkspaceAgent {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  /// SHA256 of the pairing token — unique index for fast lookup on connect.
  tokenSha     String   @unique
  /// Argon2id hash of the pairing token — verified on connect.
  tokenHash    String
  /// Shown once in the UI after creation (prefix + ellipsis), never the secret.
  tokenPrefix  String
  /// "online" while a socket is connected, "offline" otherwise.
  status       String   @default("offline")
  lastSeenAt   DateTime?
  agentVersion String?
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connections  Connection[]

  @@index([workspaceId])
}
