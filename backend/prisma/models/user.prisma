model User {
  id              String            @id @default(cuid())
  email           String            @unique
  passwordHash    String?
  displayName     String?
  density         Density           @default(MEDIUM)
  theme           Theme             @default(SYSTEM)
  oauthProvider   String?
  oauthId         String?
  emailVerifiedAt DateTime?
  /// System administrator. Grants access to /admin metrics, user listings,
  /// instance-wide audit. The very first signup is auto-promoted so a new
  /// self-host has an admin out of the box. Subsequent admins must be
  /// granted by an existing admin (or via direct SQL).
  isAdmin         Boolean           @default(false)
  /// Account lifecycle controlled by operators. Suspended users can't log in,
  /// can't use AI, and workspaces they own stop accruing usage. Never
  /// decrypted/joined with customer data — managed from the operator panel.
  suspendedAt     DateTime?
  /// Free-form reason shown to the operator (not the user) when looking at
  /// audit history. E.g. "payment failed 3x", "ToS violation: scraping".
  suspendedReason String?
  /// Operator-driven moderation gate. Sign-ups land at `pending`; an
  /// operator approves or rejects from the admin panel. Login refuses
  /// any state other than `approved`. Existing rows at the migration
  /// boundary were backfilled to `approved`.
  approvalStatus  UserApprovalStatus @default(pending)
  /// Reason displayed to the user on a rejected login. Also written on
  /// approval for audit (typically blank — "Approved by Karwan").
  approvalNote    String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  /// Which operator made the call. Soft FK (string id, no relation) so
  /// the Operator model can evolve without coupling to User migrations.
  approvedByOperatorId String?
  /// Per-day AI usage counters. Daily free allowance + workspace top-up packs
  /// both feed into the guard at request time.
  aiUsage         AiUsageDay[]
  feedbacks       Feedback[]
  announcementViews AnnouncementView[]
  abuseEvents     AbuseEvent[]
  totpSecret      TotpSecret?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  refreshTokens   RefreshToken[]
  connections     Connection[]      @relation("OwnedConnections")
  memberships     ConnectionMember[]
  auditLogs       AuditLog[]
  savedQueries    SavedQuery[]
  comments        Comment[]
  ownedWorkspaces Workspace[]       @relation("OwnedWorkspaces")
  workspaceMembers WorkspaceMember[]
  tableGrants      TableGrant[]
  scheduledQueries ScheduledQuery[]
  slowQueryLogs    SlowQueryLog[]
  webhooks         Webhook[]
  apiKeys          ApiKey[]
  columnMasks      ColumnMask[]
  emailVerifications EmailVerification[]
  passwordResets   PasswordReset[]
  schemaSnapshots  SchemaSnapshot[]
  dashboards       Dashboard[]
  sharedQueries    SharedQuery[]
  snippets         Snippet[]
  reviewRequests   QueryReviewRequest[] @relation("ReviewRequests")
  reviewsDone      QueryReviewRequest[] @relation("Reviews")
  notebooks        Notebook[]
  rowFilters       RowFilter[]
  schemaDocs       SchemaDoc[]
  incidents        Incident[]
  ownedOrganizations Organization[]       @relation("OwnedOrganizations")
  organizationMembers OrganizationMember[]
  aiChats          AiChat[]

  @@unique([oauthProvider, oauthId])
  @@index([email])
  @@index([approvalStatus, createdAt(sort: Desc)])
}
