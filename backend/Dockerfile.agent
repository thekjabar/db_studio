# syntax=docker/dockerfile:1.7
# Lightweight image for the Query Schema NETWORK AGENT.
#
# Customers run this ONE command on a machine inside their network (where the
# database's firewall/allowlist permits):
#
#   docker run -d --name queryschema-agent \
#     -e AGENT_RELAY_URL=https://database-api.mrwari.com \
#     -e AGENT_TOKEN=agt_live_xxxxx \
#     queryschema/agent
#
# It connects OUTBOUND to the relay (no inbound ports), authenticates with the
# pairing token, and runs queries against the local database. It reuses the same
# DriverFactory as the server, so behavior is identical to a direct connection.
#
# This image deliberately omits the API server, DuckDB (federated queries), and
# pg_dump (backups) — the agent doesn't need them — so it stays small.

FROM node:20-bookworm-slim

RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

# Native module toolchain (pg/mysql2/better-sqlite3/mssql) + openssl + tini.
RUN apt-get update && apt-get install -y --no-install-recommends \
      python3 make g++ openssl ca-certificates tini \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH

# Deps (cached unless package files change).
COPY package.json pnpm-lock.yaml ./
RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm config set store-dir /pnpm/store && \
    pnpm install --prefer-offline

# Prisma client is imported transitively (Dialect enum); generate it.
COPY prisma ./prisma
COPY prisma.config.ts ./prisma.config.ts
RUN DATABASE_URL="postgresql://u:p@localhost:5432/d" pnpm exec prisma generate

# Build — produces dist/agent-main.js (and the drivers it imports).
COPY src ./src
COPY nest-cli.json tsconfig.json ./
RUN NODE_OPTIONS=--max-old-space-size=1536 pnpm exec nest build

ENV NODE_ENV=production
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["node", "dist/agent-main.js"]
