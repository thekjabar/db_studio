model User {
  id              String            @id @default(cuid())
  email           String            @unique
  passwordHash    String?
  displayName     String?
  density         Density           @default(MEDIUM)
  theme           Theme             @default(SYSTEM)
  oauthProvider   String?
  oauthId         String?
  emailVerifiedAt DateTime?
  /// System administrator. Grants access to /admin metrics, user listings,
  /// instance-wide audit. The very first signup is auto-promoted so a new
  /// self-host has an admin out of the box. Subsequent admins must be
  /// granted by an existing admin (or via direct SQL).
  isAdmin         Boolean           @default(false)
  totpSecret      TotpSecret?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  refreshTokens   RefreshToken[]
  connections     Connection[]      @relation("OwnedConnections")
  memberships     ConnectionMember[]
  auditLogs       AuditLog[]
  savedQueries    SavedQuery[]
  comments        Comment[]
  ownedWorkspaces Workspace[]       @relation("OwnedWorkspaces")
  workspaceMembers WorkspaceMember[]
  tableGrants      TableGrant[]
  scheduledQueries ScheduledQuery[]
  slowQueryLogs    SlowQueryLog[]
  webhooks         Webhook[]
  apiKeys          ApiKey[]
  columnMasks      ColumnMask[]
  emailVerifications EmailVerification[]
  passwordResets   PasswordReset[]
  schemaSnapshots  SchemaSnapshot[]
  dashboards       Dashboard[]

  @@unique([oauthProvider, oauthId])
  @@index([email])
}
