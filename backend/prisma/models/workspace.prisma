model Workspace {
  id          String             @id @default(cuid())
  name        String
  /// Slug used in URLs. Must be unique.
  slug        String             @unique
  /// True for the auto-created personal workspace each user gets on signup.
  isPersonal  Boolean            @default(false)
  ownerId     String
  owner       User               @relation("OwnedWorkspaces", fields: [ownerId], references: [id], onDelete: Cascade)
  members     WorkspaceMember[]
  connections Connection[]
  sso         WorkspaceSso?
  /// Optional parent organization. Null = "personal" / no billing tenant.
  /// Existing installs keep their workspaces unscoped; new org-based
  /// deployments bind workspaces at creation time.
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  /// Billing attached to this workspace. Null until first created — owner is
  /// billing contact; seat count derives from WorkspaceMember.
  subscription   Subscription?
  billingAdjustments BillingAdjustment[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([ownerId])
  @@index([organizationId])
}

model WorkspaceMember {
  id          String      @id @default(cuid())
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Reuses the connection-level Role enum for simplicity.
  role        Role        @default(VIEWER)
  createdAt   DateTime    @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}
