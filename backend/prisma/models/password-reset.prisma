/// One-time token for resetting a forgotten password. Same hashed-at-rest
/// shape as EmailVerification; separate model so the two flows can evolve
/// independently (e.g. different TTLs, rate limits).
model PasswordReset {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenSha   String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}
